# =====================================================
# MEDICORE PROFESSIONAL SYSTEM - VARIABLES DE ENTORNO
# =====================================================
# Copia este archivo como ".env" (sin .example) y llena tus
# credenciales reales. El archivo ".env" YA está ignorado
# por git (ver .gitignore), así que nunca se subirá al
# repositorio. Mientras una API no tenga sus claves
# configuradas aquí, el módulo correspondiente se desactiva
# solo (no rompe el resto del sistema).

# ---------- URL BASE DEL SISTEMA (sin / al final) ----------
APP_URL=http://localhost/MediCore_medicoAdmin

# ---------- GOOGLE OAUTH 2.0 (login institucional) ----------
# Crear credenciales en https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/oauth_callback.php

# ---------- GOOGLE CALENDAR API (sincronizar citas) ----------
# Usa las mismas credenciales OAuth de arriba + el scope de Calendar
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=primary

# ---------- GOOGLE MAPS (módulo Ubicación) ----------
# Crear API key en https://console.cloud.google.com/google/maps-apis
# Habilitar "Maps Embed API"
GOOGLE_MAPS_API_KEY=

# ---------- OPENWEATHER (recomendaciones por clima) ----------
# Cuenta gratuita en https://openweathermap.org/api
OPENWEATHER_API_KEY=
OPENWEATHER_CIUDAD=Puebla,MX

# ---------- TWILIO (OTP / verificación por SMS) ----------
# Cuenta en https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
OTP_ENABLED=false

# ---------- SENDGRID (correos: recuperación, confirmaciones) ----------
# Cuenta gratuita (100 correos/día) en https://sendgrid.com
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=notificaciones@medicore.com
SENDGRID_FROM_NAME=MediCore Professional System
